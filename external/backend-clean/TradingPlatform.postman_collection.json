            "url": { "raw": "{{base_url}}/trade/ticker/BTC-USDT", "host": ["{{base_url}}"], "path": ["trade","ticker","BTC-USDT"] }
          },
          "response": []
        },
        {
          "name": "Place Market Buy Order",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
